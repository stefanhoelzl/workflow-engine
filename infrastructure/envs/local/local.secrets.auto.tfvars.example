# Copy this file to `local.secrets.auto.tfvars` and fill in credentials for a
# GitHub OAuth App you own. The local dev runtime uses it to drive the in-app
# OAuth handshake (packages/runtime/src/auth/routes.ts).
#
# To create the OAuth App:
#   1. GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#   2. Homepage URL:  https://localhost:8443
#   3. Authorization callback URL:  https://localhost:8443/auth/github/callback
#   4. Copy the generated Client ID + Client Secret below.

github_oauth_client_id     = "REPLACE_WITH_CLIENT_ID"
github_oauth_client_secret = "REPLACE_WITH_CLIENT_SECRET"
