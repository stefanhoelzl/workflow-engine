{
	"type": "module",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=24.0.0",
			"onFail": "download"
		}
	},
	"scripts": {
		"build": "vite build && pnpm --filter workflows build",
		"check": "tsc --build",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"test": "vitest run",
		"start": "pnpm --filter workflows build && WORKFLOW_DIR=$PWD/workflows/dist pnpm --filter @workflow-engine/runtime start"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@fission-ai/openspec": "^1.2.0",
		"@types/node": "^25.5.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.0",
		"vite": "^8.0.0",
		"vitest": "^4.0.0"
	}
}
