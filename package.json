{
	"type": "module",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "^25.9.0",
			"onFail": "download"
		}
	},
	"scripts": {
		"build": "pnpm -r build",
		"check": "tsc --build",
		"lint": "biome check --error-on-warnings .",
		"format": "biome check --write . && tofu fmt -recursive infrastructure/",
		"test": "tsc --build && pnpm --filter @workflow-engine/sandbox build && vitest run",
		"test:e2e": "pnpm --filter=\"./packages/*\" -r build && vitest run --config packages/tests/vitest.config.ts",
		"test:wpt": "tsc --build && pnpm --filter @workflow-engine/sandbox build && vitest run --config packages/sandbox-stdlib/test/wpt/vitest.config.ts",
		"test:wpt:refresh": "tsx scripts/wpt-refresh.ts",
		"validate": "concurrently -g --names lint,tsc,test,tofu-fmt,tofu-val \"pnpm lint\" \"pnpm check\" \"pnpm test\" \"tofu fmt -check -recursive infrastructure/\" \"tofu -chdir=infrastructure validate\"",
		"dev": "tsx scripts/dev.ts",
		"gh:update-secrets": "tsx scripts/gh-update-secrets.ts",
		"postinstall": "tofu -chdir=infrastructure init -backend=false || true",
		"imap": "tsx scripts/imap.ts",
		"imap:send": "tsx scripts/imap-send.ts",
		"imap:kill": "tsx scripts/imap-kill.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@fission-ai/openspec": "^1.2.0",
		"@playwright/test": "^1.59.1",
		"@types/node": "^25.5.2",
		"@workflow-engine/sdk": "workspace:*",
		"concurrently": "^9.2.1",
		"hoodiecrow-imap": "^2.1.0",
		"imapflow": "^1.3.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	}
}
