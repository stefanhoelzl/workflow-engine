{
	"type": "module",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "^25.9.0",
			"onFail": "download"
		}
	},
	"scripts": {
		"build": "pnpm -r build",
		"check": "tsc --build",
		"lint": "biome check --error-on-warnings .",
		"format": "biome check --write . && tofu fmt -recursive infrastructure/",
		"test": "vitest run",
		"validate": "concurrently -g --names lint,tsc,test,tofu-fmt,tofu-val \"pnpm lint\" \"pnpm check\" \"pnpm test\" \"tofu fmt -check -recursive infrastructure/\" \"tofu -chdir=infrastructure/dev validate\"",
		"dev": "tsx scripts/dev.ts",
		"postinstall": "tofu -chdir=infrastructure/dev init || echo 'tofu init failed'",
		"infra:init": "tofu -chdir=infrastructure/dev init",
		"infra:up": "tofu -chdir=infrastructure/dev apply",
		"infra:destroy": "tofu -chdir=infrastructure/dev destroy"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@fission-ai/openspec": "^1.2.0",
		"@types/node": "^25.5.2",
		"concurrently": "^9.2.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	}
}
