{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"files": {
		"includes": ["**", "!**/node_modules", "!**/dist"]
	},
	"linter": {
		"rules": {
			"a11y": "error",
			"complexity": "error",
			"correctness": {
				"noNodejsModules": "off"
			},
			"performance": "error",
			"security": "error",
			"style": "error",
			"suspicious": "error"
		}
	},
	"formatter": {
		"enabled": true
	},
	"overrides": [
		{
			"includes": ["vite.config.ts", "vitest.config.ts"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off",
						"noProcessEnv": "off",
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.test.ts"],
			"linter": {
				"rules": {
					"complexity": {
						"noExcessiveLinesPerFunction": "off"
					},
					"style": {
						"noMagicNumbers": "off"
					},
					"suspicious": {
						"useAwait": "off"
					}
				}
			}
		},
		{
			"includes": ["workflows/**/*.ts"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off",
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"includes": [".claude/commands/**/*.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					},
					"performance": {
						"noAwaitInLoops": "off"
					}
				}
			}
		}
	]
}
