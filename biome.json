{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/dist",
			"!.persistence",
			"!**/.terraform",
			"!packages/runtime/src/action-dispatcher.js",
			"!packages/sdk/src/plugin/sandbox-globals-setup.js",
			"!packages/sdk/src/plugin/sandbox-globals.js",
			"!packages/sandbox/dist",
			"!packages/sandbox/test/wpt/vendor"
		]
	},
	"linter": {
		"rules": {
			"a11y": "error",
			"complexity": "error",
			"correctness": {
				"noNodejsModules": "off"
			},
			"performance": "error",
			"security": "error",
			"style": "error",
			"suspicious": "error"
		}
	},
	"formatter": {
		"enabled": true
	},
	"overrides": [
		{
			"includes": ["**/vite.config.ts", "vitest.config.ts"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off",
						"noProcessEnv": "off",
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.test.ts"],
			"linter": {
				"rules": {
					"complexity": {
						"noExcessiveLinesPerFunction": "off"
					},
					"security": {
						"noSecrets": "off"
					},
					"style": {
						"noMagicNumbers": "off",
						"useNamingConvention": "off"
					},
					"suspicious": {
						"noEmptyBlockStatements": "off",
						"useAwait": "off"
					}
				}
			}
		},
		{
			"includes": ["**/storage/s3.ts"],
			"linter": {
				"rules": {
					"style": {
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"includes": ["workflows/**/*.ts"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off",
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"includes": ["scripts/**/*.ts"],
			"linter": {
				"rules": {
					"complexity": {
						"noExcessiveCognitiveComplexity": "off",
						"noExcessiveLinesPerFunction": "off"
					},
					"performance": {
						"noAwaitInLoops": "off",
						"useTopLevelRegex": "off"
					},
					"suspicious": {
						"noConsole": "off",
						"noEvolvingTypes": "off",
						"noImplicitAnyLet": "off",
						"useAwait": "off"
					},
					"style": {
						"noMagicNumbers": "off",
						"noProcessEnv": "off",
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"includes": [
				"packages/sandbox/src/polyfills/**/*.ts",
				"packages/sandbox/test/wpt/harness/preamble/**/*.ts"
			],
			"linter": {
				"rules": {
					"performance": {
						"noDelete": "off",
						"noNamespaceImport": "off"
					},
					"style": {
						"noDefaultExport": "off",
						"noMagicNumbers": "off",
						"useNamingConvention": "off"
					},
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"includes": ["packages/sandbox/test/wpt/**/*.ts"],
			"linter": {
				"rules": {
					"complexity": {
						"noExcessiveLinesPerFunction": "off"
					},
					"performance": {
						"noAwaitInLoops": "off",
						"useTopLevelRegex": "off"
					},
					"style": {
						"noDefaultExport": "off",
						"noMagicNumbers": "off",
						"noProcessEnv": "off",
						"useNamingConvention": "off"
					},
					"suspicious": {
						"noEmptyBlockStatements": "off",
						"noSkippedTests": "off",
						"useAwait": "off"
					}
				}
			}
		},
		{
			"includes": [".claude/commands/**/*.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					},
					"performance": {
						"noAwaitInLoops": "off"
					}
				}
			}
		}
	]
}
